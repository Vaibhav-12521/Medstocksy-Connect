# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
# Comma-separated list of allowed CORS origins (the Vite dev URL + your prod).
ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5173

# ── Auth ────────────────────────────────────────────────────────────────────
# Shared secret. The CRM frontend sends this in `Authorization: Bearer <…>`.
# Generate with: openssl rand -hex 32
BOT_SECRET=replace-me-with-a-long-random-hex-string

# ── Optional: Supabase write-through (audit log) ────────────────────────────
# When set, the bot writes a crm_messages + crm_send_log row after each send.
# Use the SERVICE_ROLE key here — this server runs in your control, NOT browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── WhatsApp session ────────────────────────────────────────────────────────
# Session ID — picks the on-disk session folder name. Change for multi-tenant.
SESSION_ID=medcrm
# If true, the bot prints the QR in the terminal on first run.
PRINT_QR_TO_TERMINAL=true
