{
  "name": "medcrm-wa-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Headless WhatsApp Web sender for Medstocksy Connect. Runs alongside the Vite app and exposes a small REST API so the CRM can dispatch messages without manual click-to-chat.",
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@open-wa/wa-automate": "^4.74.0",
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
