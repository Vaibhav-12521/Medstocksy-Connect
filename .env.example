# Supabase — share with the parent inventory app's project for SSO
VITE_SUPABASE_URL=https://your-project.supabase.co
# Either of these env var names works. Use whichever your other Medstocksy
# apps already use — they hold the same value (the project's "anon public" key).
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Public link to the parent inventory app (for "Switch to Inventory" deep link)
VITE_INVENTORY_APP_URL=https://app.medstocksy.in

# WhatsApp Business API (Meta or Twilio) — used by /api/whatsapp/*
# Set these on Vercel as encrypted env vars, NOT here
WHATSAPP_PROVIDER=meta            # meta | twilio
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=            # arbitrary string, set on Meta webhook
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Server-side Supabase (for webhook handlers — needs service role)
SUPABASE_SERVICE_ROLE_KEY=        # NEVER expose client-side

# Optional: error reporting
VITE_SENTRY_DSN=
